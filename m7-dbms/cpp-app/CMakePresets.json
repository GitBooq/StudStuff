{
    "version": 3,
    "configurePresets": [
        {
            "name": "vcpkg-debug",
            "toolchainFile": "/opt/vcpkg/scripts/buildsystems/vcpkg.cmake",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}